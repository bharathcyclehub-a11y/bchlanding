# ========================================
# FRONTEND ENVIRONMENT VARIABLES
# These are exposed to the browser (prefixed with VITE_) — safe.
# ========================================

# Supabase Client (frontend — anon key only)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Payment Configuration (Frontend)
# Note: Razorpay Key ID is safe to expose in frontend
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Contact Information
VITE_WHATSAPP_NUMBER=918892031480

# ========================================
# BACKEND ENVIRONMENT VARIABLES
# DO NOT PREFIX WITH VITE_ - These are server-only.
# Set these in Vercel Dashboard or .env.local. NEVER commit these to git!
# ========================================

# Supabase Admin (Backend Only — service role key bypasses RLS, CRITICAL SECURITY)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Razorpay Payment Gateway (Backend Only - CRITICAL SECURITY)
# Get these from Razorpay Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Must match the secret configured for the webhook in the Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Frontend URL for CORS (Production)
FRONTEND_URL=https://yourdomain.com
